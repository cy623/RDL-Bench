              "1 = Question",
              "2 = Answer",
              "3 = Orphaned tag wiki",
              "4 = Tag wiki excerpt",
              "5 = Tag wiki",
              "6 = Moderator nomination",
              "7 = \"Wiki placeholder\" (Appears to include auxiliary site content like the help center introduction, election description, and the tour page's introduction, ask, and don't ask sections)",
              "8 = Privilege wiki",
              "9 = Article",
              "10 = HelpArticle",
              "12 = Collection",
              "13 = ModeratorQuestionnaireResponse",
              "14 = Announcement",
              "15 = CollectiveDiscussion",
              "17 = CollectiveCollection"
            ]
          },
          {
            "name": "acceptedanswerid",
            "type": "BIGINT",
            "comment": "id of the accepted answer"
          },
          {
            "name": "creaiondate",
            "type": "TIMESTAMP",
            "comment": "when the post was created"
          },
          {
            "name": "score",
            "type": "BIGINT",
            "comment": "Total Likes/Dislikes, generally non-zero for only Questions, Answers, and Moderator Nominations"
          },
          {
            "name": "viewcount",
            "type": "BIGINT",
            "comment": "Pageviews"
          },
          {
            "name": "body",
            "type": "VARCHAR",
            "comment": "Post body in HTML format"
          },
          {
            "name": "owneruserid",
            "type": "BIGINT",
            "comment": "User Information"
          },
          {
            "name": "lastactivitydate",
            "type": "TIMESTAMP",
            "comment": "datetime of the post's most recent activity"
          },
          {
            "name": "title",
            "type": "VARCHAR",
            "comment": "question title, or on Stack Overflow, the tag name for some tag wikis and excerpts"
          },
          {
            "name": "tags",
            "type": "VARCHAR",
            "comment": "question tags, or on Stack Overflow, the subject tag of some tag wikis and excerpts"
          },
          {
            "name": "answercount",
            "type": "BIGINT",
            "comment": "the number of undeleted answers"
          },
          {
            "name": "commentcount",
            "type": "BIGINT",
            "comment": "How many comments are there under this post"
          },
          {
            "name": "favoritecount",
            "type": "BIGINT",
            "comment": "How many users have added this question to their \"favorites\" list"
          },
          {
            "name": "lasteditoruserid",
            "type": "BIGINT",
            "comment": "Who last edited this post"
          },
          {
            "name": "lasteditdate",
            "type": "TIMESTAMP",
            "comment": "the date and time of the most recent edit to the post"
          },
          {
            "name": "communityowneddate",
            "type": "TIMESTAMP",
            "comment": "The point in time when a post changed from \"personally owned\" to \"community owned\""
          },
          {
            "name": "parentid",
            "type": "BIGINT",
            "comment": "The corresponding question for answer"
          },
          {
            "name": "closeddate",
            "type": "TIMESTAMP",
            "comment": "The date when the question was closed"
          },
          {
            "name": "ownerdisplayname",
            "type": "VARCHAR",
            "comment": "If no user ID is available, record the \"author's name\" as a text file."
          },
          {
            "name": "lasteditordisplayname",
            "type": "VARCHAR",
            "comment": "The last editor's \"display name\" (when there is no UserId)"
          }
        ],
        "primary_key": [
