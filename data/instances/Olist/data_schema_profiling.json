      "table_name": "olist_customers_dataset",
      "description": "Customer dataset containing customer identifiers and delivery-location attributes. It is used to identify customers in the orders dataset and to describe customer location through zip-code prefix, city, and state.",
      "schema": {
        "columns": [
          {
            "name": "customer_id",
            "type": "VARCHAR",
            "comment": "Primary key of the customers table. In the Olist dataset, each order is assigned to a unique `customer_id`, so the same real-world customer may appear with different `customer_id` values across different orders."
          },
          {
            "name": "customer_unique_id",
            "type": "VARCHAR",
            "comment": "Stable customer identifier used to identify repeat purchases by the same customer across different orders."
          },
          {
            "name": "customer_zip_code_prefix",
            "type": "VARCHAR",
            "comment": "Prefix of the customer's ZIP code."
          },
          {
            "name": "customer_city",
            "type": "VARCHAR",
