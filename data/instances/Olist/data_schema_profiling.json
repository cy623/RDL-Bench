    {
      "table_name": "olist_orders_dataset",
      "description": "Orders dataset containing one row per order and its lifecycle timestamps. It links each order to a customer and records the order status, purchase time, approval time, carrier handoff time, customer delivery time, and estimated delivery date.",
      "schema": {
        "columns": [
          {
            "name": "order_id",
            "type": "VARCHAR",
            "comment": "Primary key of the orders table; unique identifier of the order."
          },
          {
            "name": "customer_id",
            "type": "VARCHAR",
            "comment": "Identifier of the customer associated with the order; foreign key to `olist_customers_dataset.customer_id`."
          },
          {
            "name": "order_status",
            "type": "VARCHAR",
            "comment": "Current status of the order."
          },
          {
            "name": "order_purchase_timestamp",
            "type": "TIMESTAMP",
            "comment": "Timestamp when the order was placed."
          },
          {
            "name": "order_approved_at",
            "type": "TIMESTAMP",
            "comment": "Timestamp when the payment for the order was approved."
          },
          {
            "name": "order_delivered_carrier_date",
            "type": "TIMESTAMP",
            "comment": "Timestamp when the order was handed over to the logistics carrier."
          },
          {
            "name": "order_delivered_customer_date",
            "type": "TIMESTAMP",
            "comment": "Timestamp when the order was delivered to the customer."
          },
          {
            "name": "order_estimated_delivery_date",
            "type": "TIMESTAMP",
            "comment": "Estimated date when the order was expected to be delivered to the customer."
          }
        ],
        "primary_key": [
          "order_id"
        ],
        "foreign_keys": [
          {
            "column": "customer_id",
            "references": "olist_customers_dataset.customer_id"
          }
        ]
      },
