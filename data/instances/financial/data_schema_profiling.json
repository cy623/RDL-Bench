    {
      "table_name": "disp",
      "description": "each record relates together a client with an account i.e. this relation describes the rights of clients to operate accounts.",
      "schema": {
        "columns": [
          {
            "name": "disp_id",
            "type": "BIGINT",
            "comment": "record identifier"
          },
          {
