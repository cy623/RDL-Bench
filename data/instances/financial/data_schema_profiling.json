            "name": "payments",
            "type": "DOUBLE",
            "comment": "monthly payments"
          },
          {
            "name": "status",
            "type": "VARCHAR",
            "comment": "status of paying off the loan: 'A' stands for contract finished, no problems, 'B' stands for contract finished, loan not payed,'C' stands for running contract, OK so far,'D' stands for running contract, client in debt."
          }
        ],
        "primary_key": [
          "loan_id"
        ],
        "foreign_keys": [
