          {
            "name": "account_id",
            "type": "BIGINT",
            "comment": "identification of an account"
          },
          {
            "name": "type",
            "type": "VARCHAR",
            "comment": "type of disposition (owner/user), only owner can issue permanent orders and ask for a loan"
