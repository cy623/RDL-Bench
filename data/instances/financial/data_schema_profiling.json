    {
      "table_name": "trans",
      "description": "each record describes one transaction on an account.",
      "schema": {
        "columns": [
          {
            "name": "trans_id",
            "type": "BIGINT",
            "comment": "record identifier"
          },
          {
            "name": "account_id",
            "type": "BIGINT",
            "comment": "account, the transation deals with"
          },
          {
            "name": "date",
            "type": "DATE",
            "comment": "date of transaction"
          },
          {
            "name": "type",
            "type": "VARCHAR",
            "comment": "+/- transaction \"PRIJEM\" stands for credit, \"VYDAJ\" stands for withdrawal."
          },
          {
            "name": "operation",
            "type": "VARCHAR",
            "comment": "mode of transaction:\"VYBER KARTOU\" credit card withdrawal, \"VKLAD\" credit in cash,\"PREVOD Z UCTU\" collection from another bank,\"VYBER\" withdrawal in cash,\"PREVOD NA UCET\" remittance to another bank."
          },
          {
            "name": "amount",
            "type": "BIGINT",
            "comment": "amount of money"
          },
          {
            "name": "balance",
            "type": "BIGINT",
            "comment": "balance after transaction"
          },
          {
            "name": "k_symbol",
            "type": "VARCHAR",
            "comment": "characterization of the transaction: \"POJISTNE\" stands for insurrance payment,\"SLUZBY\" stands for payment for statement,\"UROK\" stands for interest credited,\"SANKC.UROK\" sanction interest if negative balance,\"SIPO\" stands for household,\"DUCHOD\" stands for old-age pension,\"UVER\" stands for loan payment."
          },
          {
            "name": "bank",
            "type": "VARCHAR",
            "comment": "bank of the partner, each bank has unique two-letter code"
          },
          {
            "name": "account",
            "type": "BIGINT",
            "comment": "account of the partner"
          }
        ],
        "primary_key": [
          "trans_id"
        ],
        "foreign_keys": [
          {
            "column": "account_id",
            "references": "account.account_id"
          }
        ]
      },
