            "comment": "disposition to an account"
          },
          {
            "name": "type",
            "type": "VARCHAR",
            "comment": "type of card, possible values are \"junior\", \"classic\", \"gold\""
          },
          {
            "name": "issued",
            "type": "DATE",
            "comment": "issue date"
          }
