    {
      "table_name": "loan",
      "description": "each record describes a loan granted for a given account.",
      "schema": {
        "columns": [
          {
            "name": "loan_id",
            "type": "BIGINT",
            "comment": "record identifier"
          },
          {
            "name": "account_id",
            "type": "BIGINT",
            "comment": "identification of the account"
